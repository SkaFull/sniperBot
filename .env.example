# RPC Configuration
RPC_URL=https://api.mainnet-beta.solana.com
RPC_WS_URL=wss://api.mainnet-beta.solana.com

# Wallet Configuration
PRIVATE_KEY=your_private_key_here

# Sniper Configuration
USE_TPU_DIRECT=true
SEND_TO_MULTIPLE_LEADERS=true
PRE_SEND_LEADER_COUNT=2
TIMEOUT=5000
MAX_RETRIES=3

# Cache Configuration (milliseconds)
LEADER_CACHE_TTL=300000
CLUSTER_NODES_CACHE_TTL=600000
VOTE_ACCOUNTS_CACHE_TTL=300000

# Log Configuration
LOG_LEVEL=info

# Trading Configuration
BUY_AMOUNT=0.1
JITO_TIP=0.001
TAKE_PROFIT=2.0
STOP_LOSS=0.5
TRAILING_STOP=0.2

# Security Configuration
MAX_TOP10_HOLDERS=30
MIN_LP_LOCKED=95